{
  "name": "quiltplannerpro",
  "private": true,
  "version": "0.3.00002",
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c magenta,cyan \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "version:show": "node scripts/version-manager.js show",
    "version:sync": "node scripts/version-manager.js sync",
    "version:bump": "node scripts/version-manager.js bump",
    "version:bump:incr": "node scripts/version-manager.js bump incr",
    "version:bump:minor": "node scripts/version-manager.js bump minor",
    "version:bump:major": "node scripts/version-manager.js bump major"
  },
  "dependencies": {
    "axios": "^1.13.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
